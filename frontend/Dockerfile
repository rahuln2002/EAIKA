FROM node:20-alpine

# =====================================================
# WORKDIR
# =====================================================

WORKDIR /app

# =====================================================
# COPY PACKAGE FILES
# =====================================================

COPY package*.json ./

# =====================================================
# INSTALL DEPENDENCIES
# =====================================================

RUN npm install

# =====================================================
# COPY APPLICATION
# =====================================================

COPY . .

# =====================================================
# BUILD NEXT.JS APP
# =====================================================

RUN npm run build

# =====================================================
# EXPOSE PORT
# =====================================================

EXPOSE 3000

# =====================================================
# START APPLICATION
# =====================================================

CMD ["npm", "start"]
