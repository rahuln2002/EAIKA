# App
APP_NAME=EAIKA
ENVIRONMENT=development
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eai_ka
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eai_ka

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# OpenAI
OPENAI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en

# Logging
LOG_LEVEL=INFO
